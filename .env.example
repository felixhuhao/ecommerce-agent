# LLM (OpenAI-compatible)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
# DEEPSEEK_API_KEY= # Optional alias for LLM_API_KEY
LLM_MODEL=deepseek-chat

# SpringBoot MCP server (business tools, assumed running)
SPRING_MCP_URL=http://localhost:8080/mcp
SPRING_MCP_SERVICE_TOKEN=dev-service-token
SPRING_MCP_USER_ID=1
SPRING_MCP_SESSION_ID=local-session

# M2 sessions, persisted thread, and approval REST orchestration
# Mongo runs authenticated (root user created by MONGO_INITDB_ROOT_* in docker-compose.yml,
# living in the admin DB — hence authSource=admin). Local-dev creds only.
MONGO_INITDB_ROOT_USERNAME=ecommerce_agent
MONGO_INITDB_ROOT_PASSWORD=dev-mongo-password
MONGO_URL=mongodb://ecommerce_agent:dev-mongo-password@localhost:27017/?authSource=admin
MONGO_DB=ecommerce_agent
APPROVAL_API_BASE_URL=http://localhost:8080
SESSION_IDLE_TTL_SECONDS=1800
MAX_LIVE_SESSIONS=50

# Optional chart MCP server (AntV/ModelScope chart tools)
# Start with: docker compose -f compose.chart-mcp.yml up chart-mcp
# If port 1122 is already in use, set CHART_MCP_PORT=1123 and use that port below.
MODELSCOPE_MCP_URL=

# Sandbox executor (design doc §6.2/§6.6).
# Backend: "docker" (in-container DockerSandbox, default) or "remote" (executor service).
# In "remote" mode, start the executor first:
#   docker compose -f docker-compose.yml -f compose.chart-mcp.yml -f compose.sandbox.yml up -d sandbox-executor
SANDBOX_BACKEND=docker
SANDBOX_EXECUTOR_URL=http://localhost:8006
SANDBOX_EXECUTOR_TOKEN=dev-sandbox-token
SANDBOX_EXECUTOR_PORT=8006

# Future MCP servers
PYTHON_MCP_URL=
